@{
    ViewBag.Title = "Inicio";
}

<div class="container" style="margin-top: 40px;">

    <div class="jumbotron">
        <h1>TechHelpWeb</h1>

        <p class="lead">
            Sistema de solicitudes de soporte técnico.
        </p>

        <p>
            Bienvenido/a, <strong>@Session["NombreCompleto"]</strong>
        </p>
    </div>

    <div class="row">

        <div class="col-md-4">
            <h3>Solicitudes</h3>
            <p>
                Registrar y revisar solicitudes de soporte técnico.
            </p>
            <p>
                <a class="btn btn-primary" href="@Url.Action("Index", "Solicitudes")">
                    Ir a Solicitudes
                </a>
            </p>
        </div>

        <div class="col-md-4">
            <h3>Perfil</h3>
            <p>
                Ver o actualizar los datos del usuario.
            </p>
            <p>
                <a class="btn btn-default" href="#">
                    Próximamente
                </a>
            </p>
        </div>

        <div class="col-md-4">
            <h3>Cerrar sesión</h3>
            <p>
                Salir del sistema de forma segura.
            </p>
            <p>
                <a class="btn btn-danger" href="@Url.Action("Logout", "Auth")">
                    Cerrar sesión
                </a>
            </p>
        </div>

    </div>

</div>