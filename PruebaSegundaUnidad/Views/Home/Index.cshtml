@{
    ViewBag.Title = "Dashboard Administrativo";
}

<div class="row">
    <div class="col-md-12">
        <h2 class="page-header"><i class="fa fa-chart-line"></i> Dashboard Principal</h2>
        <p class="lead">Bienvenido/a, <strong>@Session["NombreCompleto"]</strong></p>
    </div>
</div>

@* Solo los administradores o personal de soporte ven las métricas *@
@if (Session["Rol"] != null && (Session["Rol"].ToString() == "Administrador" || Session["Rol"].ToString() == "Soporte"))
{
    <div class="row">
        <div class="col-md-3">
            <div class="dash-card bg-primary-dark">
                <i class="fa fa-users bg-icon"></i>
                <h1>@(ViewBag.TotalUsuarios ?? 0)</h1>
                <h4>Usuarios Activos</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card bg-danger">
                <i class="fa fa-exclamation-circle bg-icon"></i>
                <h1>@(ViewBag.Pendientes ?? 0)</h1>
                <h4>Tickets Pendientes</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card bg-warning">
                <i class="fa fa-spinner bg-icon"></i>
                <h1 style="color: #333;">@(ViewBag.EnProceso ?? 0)</h1>
                <h4 style="color: #333;">En Proceso</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card bg-success">
                <i class="fa fa-check-circle bg-icon"></i>
                <h1>@(ViewBag.Resueltas ?? 0)</h1>
                <h4>Resueltas</h4>
            </div>
        </div>
    </div>
}

<div class="row" style="margin-top: 20px;">
    <div class="col-md-12">
        <h3>Accesos Rápidos</h3>
        <hr />

        <a href="@Url.Action("Index", "Solicitudes")" class="btn btn-primary btn-lg">
            <i class="fa fa-ticket-alt"></i> Gestión de Soporte
        </a>

        <a href="@Url.Action("Index", "Perfil")" class="btn btn-default btn-lg">
            <i class="fa fa-user-circle"></i> Cambiar Contraseña
        </a>

        @* Solo el Administrador puede gestionar a otros usuarios *@
        @if (Session["Rol"] != null && Session["Rol"].ToString() == "Administrador")
        {
            <a href="@Url.Action("Index", "Usuarios")" class="btn btn-danger btn-lg">
                <i class="fa fa-users-cog"></i> Gestión de Usuarios
            </a>
        }
    </div>
</div>