@{
    ViewBag.Title = "Dashboard Administrativo";
}

<div class="row">
    <div class="col-md-12">

        <h2 class="page-header">Dashboard Principal</h2>

        @* Muestra el nombre del usuario conectado *@
        <p class="lead">
            Bienvenido/a, <strong>@Session["NombreCompleto"]</strong>
        </p>

    </div>
</div>

@* Solo Administrador y Soporte ven las métricas generales *@
@if (Session["Rol"] != null &&
    (Session["Rol"].ToString() == "Administrador" || Session["Rol"].ToString() == "Soporte"))
{
    <div class="row">

        <div class="col-md-3">
            <div class="dash-card bg-primary-dark">
                <h1>@(ViewBag.TotalUsuarios ?? 0)</h1>
                <h4>Usuarios Activos</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card bg-danger">
                <h1>@(ViewBag.Pendientes ?? 0)</h1>
                <h4>Tickets Pendientes</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card bg-warning">
                <h1 style="color: #FFFFFF;">@(ViewBag.EnProceso ?? 0)</h1>
                <h4 style="color: #FFFFFF;">En Proceso</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card bg-success">
                <h1>@(ViewBag.Resueltas ?? 0)</h1>
                <h4>Resueltas</h4>
            </div>
        </div>

    </div>
}

<div class="row" style="margin-top: 20px;">
    <div class="col-md-12">

        <h3>Accesos Rápidos</h3>
        <hr />

        @* Acceso al módulo principal de solicitudes *@
        <a href="@Url.Action("Index", "Solicitudes")" class="btn btn-primary btn-lg">
            Gestión de Soporte
        </a>

        @* Acceso al perfil del usuario conectado *@
        <a href="@Url.Action("Index", "Perfil")" class="btn btn-default btn-lg">
            Cambiar Contraseña
        </a>

        @* Solo el Administrador puede gestionar usuarios *@
        @if (Session["Rol"] != null && Session["Rol"].ToString() == "Administrador")
        {
            <a href="@Url.Action("Index", "Usuarios")" class="btn btn-danger btn-lg">
                Gestión de Usuarios
            </a>
        }

    </div>
</div>