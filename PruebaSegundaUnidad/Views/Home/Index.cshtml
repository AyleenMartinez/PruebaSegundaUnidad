@{
    ViewBag.Title = "Dashboard";

    var rol = Session["Rol"] != null ? Session["Rol"].ToString() : "";

    var esAdministrador = ViewBag.EsAdministrador == true;
    var esSoporte = ViewBag.EsSoporte == true;
    var esUsuario = ViewBag.EsUsuario == true;
}

<div class="dashboard-page">

    <div class="dashboard-hero">

        <div>
            <span class="dashboard-etiqueta">
                @if (esAdministrador)
                {
                    @:Panel administrativo
                }
                else if (esSoporte)
                {
                    @:Panel de soporte
                }
                else
                {
                    @:Panel personal
                }
            </span>

            <h2>Dashboard principal</h2>

            <p>
                Bienvenido/a, <strong>@Session["NombreCompleto"]</strong>
            </p>

            @if (esAdministrador)
            {
                <small>Vista general del sistema, usuarios y solicitudes registradas.</small>
            }
            else if (esSoporte)
            {
                <small>Vista de seguimiento para revisar y actualizar tickets de soporte.</small>
            }
            else
            {
                <small>Vista personal para crear solicitudes y revisar el avance de tus tickets.</small>
            }
        </div>

    </div>

    <div class="row dashboard-metricas">

        <div class="col-md-3">
            <div class="dash-card dash-morado">
                <span>
                    @if (esAdministrador)
                    {
                        @:Usuarios activos
                    }
                    else if (esSoporte)
                    {
                        @:Total tickets
                    }
                    else
                    {
                        @:Mis tickets
                    }
                </span>

                <strong>
                    @if (esAdministrador)
                    {
                        @(ViewBag.TotalUsuarios ?? 0)
                    }
                    else
                    {
                        @(ViewBag.TotalSolicitudes ?? 0)
                    }
                </strong>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card dash-rojo">
                <span>Pendientes</span>
                <strong>@(ViewBag.Pendientes ?? 0)</strong>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card dash-naranja">
                <span>En proceso</span>
                <strong>@(ViewBag.EnProceso ?? 0)</strong>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dash-card dash-verde">
                <span>Resueltas</span>
                <strong>@(ViewBag.Resueltas ?? 0)</strong>
            </div>
        </div>

    </div>

    <div class="dashboard-panel">

        <div class="dashboard-panel-header">
            <div>
                <h3>Accesos rápidos</h3>

                @if (esAdministrador)
                {
                    <p>Administra solicitudes, usuarios y datos de tu cuenta.</p>
                }
                else if (esSoporte)
                {
                    <p>Revisa tickets y actualiza estados de atención.</p>
                }
                else
                {
                    <p>Crea una solicitud o revisa el estado de tus tickets.</p>
                }
            </div>
        </div>

        <div class="dashboard-accesos">

            <a href="@Url.Action("Index", "Solicitudes")" class="dashboard-acceso acceso-soporte">
                <span>Solicitudes</span>

                @if (esUsuario)
                {
                    <small>Crear o revisar mis tickets</small>
                }
                else
                {
                    <small>Gestionar soporte técnico</small>
                }
            </a>

            <a href="@Url.Action("Index", "Perfil")" class="dashboard-acceso acceso-perfil">
                <span>Mi perfil</span>
                <small>Datos personales y contraseña</small>
            </a>

            @if (esAdministrador)
            {
                <a href="@Url.Action("Index", "Usuarios")" class="dashboard-acceso acceso-usuarios">
                    <span>Usuarios</span>
                    <small>Crear, editar y activar cuentas</small>
                </a>
            }

        </div>

    </div>

</div>