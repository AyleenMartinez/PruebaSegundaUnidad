@model PruebaSegundaUnidad.Models.PerfilViewModel

@{
    ViewBag.Title = "Mi Perfil";
}

@* CSS reutilizable para el botón Ver/Ocultar contraseña *@
<link href="@Url.Content("~/Content/password-toggle.css")" rel="stylesheet" />

@* CSS propio de la vista Perfil. El ?v=4 fuerza al navegador a cargar los estilos nuevos *@
<link href="@Url.Content("~/Content/perfil.css?v=4")" rel="stylesheet" />

<div class="perfil-page">

    <div class="perfil-hero">

        <div>
            <span class="perfil-etiqueta">Cuenta personal</span>

            <h2>Mi perfil</h2>

            <p>
                Revisa tus datos de cuenta y actualiza tu contraseña de acceso al sistema.
            </p>
        </div>

        <div class="perfil-resumen">
            <span>Sesión activa</span>
            <strong>@Model.NombreCompleto</strong>
            <small>@Model.Correo</small>
        </div>

    </div>

    <div class="row perfil-grid">

        <div class="col-md-5">

            <div class="perfil-card">

                <div class="perfil-card-header">
                    <h3>Datos personales</h3>
                    <p>Información básica asociada a tu cuenta.</p>
                </div>

                @* Formulario MVC para actualizar solo el nombre completo *@
                @using (Html.BeginForm("ActualizarDatos", "Perfil", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    @* Se mantiene el Id del usuario en el formulario *@
                    @Html.HiddenFor(m => m.UsuarioId)

                    <div class="form-group perfil-form-group">
                        <label>Nombre completo <span class="text-danger">*</span></label>

                        @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control" })

                        @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group perfil-form-group">
                        <label>Correo</label>

                        @* El correo se muestra, pero no se edita desde Mi Perfil *@
                        @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email", @readonly = "readonly" })

                        <small class="perfil-ayuda">
                            El correo está asociado a la cuenta y no se modifica desde esta pantalla.
                        </small>
                    </div>

                    @* Mensaje de éxito para datos personales *@
                    if (TempData["MensajePerfil"] != null)
                    {
                        <div class="alert alert-success perfil-alerta">
                            @TempData["MensajePerfil"]
                        </div>
                    }

                    <button type="submit" class="btn btn-perfil-guardar">
                        Guardar datos
                    </button>
                }

            </div>

        </div>

        <div class="col-md-7">

            <div class="perfil-card perfil-card-seguridad">

                <div class="perfil-card-header">
                    <h3>Seguridad de acceso</h3>
                    <p>Cambia tu contraseña validando primero la clave actual.</p>
                </div>

                @* Mensaje de éxito para cambio de contraseña *@
                @if (TempData["MensajeClave"] != null)
                {
                    <div class="alert alert-success perfil-alerta">
                        @TempData["MensajeClave"]
                    </div>
                }

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                @* Formulario MVC para cambiar contraseña *@
                @using (Html.BeginForm("ActualizarClave", "Perfil", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    @* Estos campos mantienen los datos del perfil si el formulario vuelve con errores *@
                    @Html.HiddenFor(m => m.UsuarioId)
                    @Html.HiddenFor(m => m.NombreCompleto)
                    @Html.HiddenFor(m => m.Correo)

                    <div class="form-group perfil-form-group">
                        <label>Contraseña actual <span class="text-danger">*</span></label>

                        <div class="password-wrapper">
                            @Html.PasswordFor(m => m.ClaveActual, new { @class = "form-control", id = "ClaveActual" })

                            <button type="button"
                                    class="password-toggle"
                                    data-target="ClaveActual">
                                Ver
                            </button>
                        </div>

                        @Html.ValidationMessageFor(m => m.ClaveActual, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group perfil-form-group">
                        <label>Nueva contraseña <span class="text-danger">*</span></label>

                        <div class="password-wrapper">
                            @Html.PasswordFor(m => m.NuevaClave, new { @class = "form-control", id = "NuevaClave" })

                            <button type="button"
                                    class="password-toggle"
                                    data-target="NuevaClave">
                                Ver
                            </button>
                        </div>

                        @Html.ValidationMessageFor(m => m.NuevaClave, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group perfil-form-group">
                        <label>Confirmar nueva contraseña <span class="text-danger">*</span></label>

                        <div class="password-wrapper">
                            @Html.PasswordFor(m => m.ConfirmarClave, new { @class = "form-control", id = "ConfirmarClave" })

                            <button type="button"
                                    class="password-toggle"
                                    data-target="ConfirmarClave">
                                Ver
                            </button>
                        </div>

                        @Html.ValidationMessageFor(m => m.ConfirmarClave, "", new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-perfil-clave">
                        Cambiar contraseña
                    </button>
                }

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    @* Script reutilizable para mostrar u ocultar contraseñas *@
    <script src="@Url.Content("~/Scripts/app/password-toggle.js?v=1")"></script>
}