@model PruebaSegundaUnidad.Models.PerfilViewModel

@{
    // Título que se muestra en la pestaña y en el layout.
    ViewBag.Title = "Mi Perfil";
}

<div class="row">

    @* Contenedor principal centrado *@
    <div class="col-md-6 col-md-offset-3">

        <h2>Mi Perfil</h2>

        @*
            Antes: aquí estaba el botón "Volver al panel".
            Ahora: se eliminó porque el botón "← Volver" ya está en el _Layout
            y aparece de forma general en todas las vistas internas.
        *@

        @* Panel principal del perfil *@
        <div class="panel panel-default">
            <div class="panel-body">

                @* Datos básicos del usuario conectado *@
                <p><strong>Nombre:</strong> @Model.NombreCompleto</p>
                <p><strong>Correo:</strong> @Model.Correo</p>

                <hr />

                @* Mensaje que aparece si la contraseña se actualizó correctamente *@
                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["MensajeExito"]
                    </div>
                }

                @* Muestra errores generales del formulario *@
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                @* Formulario que envía los datos al método ActualizarClave del PerfilController *@
                @using (Html.BeginForm("ActualizarClave", "Perfil", FormMethod.Post))
                {
                    @* Token de seguridad para evitar envíos falsos *@
                    @Html.AntiForgeryToken()

                    @* Id del usuario conectado *@
                    @Html.HiddenFor(m => m.UsuarioId)

                    @* Campo contraseña actual *@
                    <div class="form-group">
                        <label>Contraseña actual <span class="text-danger">*</span></label>

                        <div class="input-group">
                            @* Campo oculto como contraseña *@
                            @Html.PasswordFor(m => m.ClaveActual, new { @class = "form-control", id = "ClaveActual" })

                            @* Botón para mostrar u ocultar la contraseña *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="ClaveActual">
                                    Ver
                                </button>
                            </span>
                        </div>

                        @* Error específico de contraseña actual *@
                        @Html.ValidationMessageFor(m => m.ClaveActual, "", new { @class = "text-danger" })
                    </div>

                    @* Campo nueva contraseña *@
                    <div class="form-group">
                        <label>Nueva contraseña <span class="text-danger">*</span></label>

                        <div class="input-group">
                            @* Campo conectado con NuevaClave del ViewModel *@
                            @Html.PasswordFor(m => m.NuevaClave, new { @class = "form-control", id = "NuevaClave" })

                            @* Botón para mostrar u ocultar la nueva contraseña *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="NuevaClave">
                                    Ver
                                </button>
                            </span>
                        </div>

                        @* Error de campo obligatorio o largo mínimo *@
                        @Html.ValidationMessageFor(m => m.NuevaClave, "", new { @class = "text-danger" })
                    </div>

                    @* Campo confirmar nueva contraseña *@
                    <div class="form-group">
                        <label>Confirmar nueva contraseña <span class="text-danger">*</span></label>

                        <div class="input-group">
                            @* Este campo se compara con NuevaClave desde el ViewModel *@
                            @Html.PasswordFor(m => m.ConfirmarClave, new { @class = "form-control", id = "ConfirmarClave" })

                            @* Botón para mostrar u ocultar la confirmación *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="ConfirmarClave">
                                    Ver
                                </button>
                            </span>
                        </div>

                        @* Error si la confirmación no coincide *@
                        @Html.ValidationMessageFor(m => m.ConfirmarClave, "", new { @class = "text-danger" })
                    </div>

                    @* Botón que envía el formulario *@
                    <button type="submit" class="btn btn-primary">
                        Cambiar contraseña
                    </button>
                }

            </div>
        </div>

    </div>
</div>

<script>
    // Se buscan todos los botones para ver u ocultar contraseña.
    var botonesPassword = document.querySelectorAll(".btn-ver-password");

    // Se recorre cada botón encontrado.
    for (var i = 0; i < botonesPassword.length; i++) {

        // Se agrega el evento click a cada botón.
        botonesPassword[i].addEventListener("click", function () {

            // Se obtiene el id del campo asociado a este botón.
            var idCampo = this.getAttribute("data-target");

            // Se busca el campo de contraseña.
            var campo = document.getElementById(idCampo);

            // Si no encuentra el campo, se detiene.
            if (campo == null) {
                return;
            }

            // Si está oculto como password, se muestra como texto.
            if (campo.type === "password") {
                campo.type = "text";
                this.textContent = "Ocultar";
            }

            // Si ya está visible, se vuelve a ocultar.
            else {
                campo.type = "password";
                this.textContent = "Ver";
            }
        });
    }
</script>