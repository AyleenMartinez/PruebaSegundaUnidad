@model PruebaSegundaUnidad.Models.PerfilViewModel

@{
    // Título de la página dentro del layout.
    ViewBag.Title = "Mi Perfil";
}

<div class="row">

    @* Columna centrada para que el formulario no ocupe todo el ancho *@
    <div class="col-md-6 col-md-offset-3">

        @* Encabezado superior de la vista *@
        <div class="clearfix">

            @* Título principal de la pantalla *@
            <h2 class="pull-left">Mi Perfil</h2>

            @* Botón para cerrar la sesión del usuario *@
            <a href="@Url.Action("Logout", "Auth")" class="btn btn-danger pull-right" style="margin-top: 20px;">
                Cerrar sesión
            </a>

        </div>

        @* Botón para volver al panel principal del sistema *@
        <a href="@Url.Action("Index", "Home")" class="btn btn-default" style="margin-bottom: 15px;">
            Volver al panel
        </a>

        @* Panel visual que contiene los datos y el formulario *@
        <div class="panel panel-default">
            <div class="panel-body">

                @* Datos básicos del usuario conectado *@
                <p><strong>Nombre:</strong> @Model.NombreCompleto</p>
                <p><strong>Correo:</strong> @Model.Correo</p>

                <hr />

                @* Mensaje que aparece cuando la contraseña fue cambiada correctamente *@
                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["MensajeExito"]
                    </div>
                }

                @* Muestra errores generales del formulario *@
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                @* Formulario que envía los datos al método ActualizarClave del PerfilController *@
                @using (Html.BeginForm("ActualizarClave", "Perfil", FormMethod.Post))
                {
                    @* Token de seguridad para evitar envíos falsos del formulario *@
                    @Html.AntiForgeryToken()

                    @* Campo oculto con el Id del usuario *@
                    @Html.HiddenFor(m => m.UsuarioId)

                    @* Campo de contraseña actual *@
                    <div class="form-group">

                        @* Etiqueta visible para el usuario *@
                        <label>Contraseña actual <span class="text-danger">*</span></label>

                        @* Input group permite poner el botón Ver al lado del input *@
                        <div class="input-group">

                            @* Campo que oculta la contraseña mientras se escribe *@
                            @Html.PasswordFor(m => m.ClaveActual, new { @class = "form-control", id = "ClaveActual" })

                            @* Botón que cambia entre mostrar y ocultar contraseña *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="ClaveActual">
                                    Ver
                                </button>
                            </span>

                        </div>

                        @* Mensaje de error específico para contraseña actual *@
                        @Html.ValidationMessageFor(m => m.ClaveActual, "", new { @class = "text-danger" })

                    </div>

                    @* Campo de nueva contraseña *@
                    <div class="form-group">

                        @* Etiqueta del campo nueva contraseña *@
                        <label>Nueva contraseña <span class="text-danger">*</span></label>

                        @* Input group para agregar el botón Ver *@
                        <div class="input-group">

                            @* Campo conectado con NuevaClave del ViewModel *@
                            @Html.PasswordFor(m => m.NuevaClave, new { @class = "form-control", id = "NuevaClave" })

                            @* Botón para mostrar u ocultar la nueva contraseña *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="NuevaClave">
                                    Ver
                                </button>
                            </span>

                        </div>

                        @* Muestra errores como campo vacío o contraseña menor a 6 caracteres *@
                        @Html.ValidationMessageFor(m => m.NuevaClave, "", new { @class = "text-danger" })

                    </div>

                    @* Campo para confirmar la contraseña nueva *@
                    <div class="form-group">

                        @* Etiqueta del campo confirmar contraseña *@
                        <label>Confirmar nueva contraseña <span class="text-danger">*</span></label>

                        @* Input group para agregar el botón Ver *@
                        <div class="input-group">

                            @* Campo que se compara con NuevaClave desde el ViewModel *@
                            @Html.PasswordFor(m => m.ConfirmarClave, new { @class = "form-control", id = "ConfirmarClave" })

                            @* Botón para mostrar u ocultar la confirmación *@
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-ver-password" data-target="ConfirmarClave">
                                    Ver
                                </button>
                            </span>

                        </div>

                        @* Muestra error si la confirmación no coincide *@
                        @Html.ValidationMessageFor(m => m.ConfirmarClave, "", new { @class = "text-danger" })

                    </div>

                    @* Botón principal que envía el formulario *@
                    <button type="submit" class="btn btn-primary">
                        Cambiar contraseña
                    </button>
                }

            </div>
        </div>

    </div>
</div>

<script>
    // Se buscan todos los botones que sirven para ver u ocultar contraseñas.
    var botonesPassword = document.querySelectorAll(".btn-ver-password");

    // Se recorre cada botón encontrado.
    for (var i = 0; i < botonesPassword.length; i++) {

        // Se agrega el evento click a cada botón.
        botonesPassword[i].addEventListener("click", function () {

            // Se obtiene el id del campo que debe controlar este botón.
            var idCampo = this.getAttribute("data-target");

            // Se busca el input usando el id obtenido.
            var campo = document.getElementById(idCampo);

            // Si no encuentra el campo, se detiene para evitar errores.
            if (campo == null) {
                return;
            }

            // Si el campo está como password, se cambia a texto visible.
            if (campo.type === "password") {
                campo.type = "text";
                this.textContent = "Ocultar";
            }

            // Si el campo ya está visible, se vuelve a ocultar.
            else {
                campo.type = "password";
                this.textContent = "Ver";
            }
        });
    }
</script>