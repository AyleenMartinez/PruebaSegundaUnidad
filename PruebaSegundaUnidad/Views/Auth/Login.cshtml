@model PruebaSegundaUnidad.Models.LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
}

@* CSS propio del login *@
<link href="@Url.Content("~/Content/login.css")" rel="stylesheet" />

@* CSS reutilizable para el botón Ver/Ocultar contraseña *@
<link href="@Url.Content("~/Content/password-toggle.css")" rel="stylesheet" />

<div class="login-page">
    <div class="panel panel-primary login-card">

        <div class="panel-heading text-center">
            <h3>TechHelpWeb</h3>
        </div>

        <div class="panel-body">

            @* Muestra errores generales del login, como usuario incorrecto o cuenta inactiva *@
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger login-error">
                    @ViewBag.Error
                </div>
            }

            @* Formulario que envía los datos al método Login del AuthController *@
            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                @* Token de seguridad para proteger el formulario *@
                @Html.AntiForgeryToken()

                <div class="form-group login-form-group">
                    <label>Usuario o Correo</label>

                    @* Campo para escribir nombre de usuario o correo *@
                    @Html.TextBoxFor(m => m.UsuarioOCorreo, new { @class = "form-control" })

                    @* Mensaje de validación para usuario/correo obligatorio *@
                    @Html.ValidationMessageFor(m => m.UsuarioOCorreo, "", new { @class = "text-danger login-validacion" })
                </div>

                <div class="form-group login-form-group">
                    <label>Contraseña</label>

                    <div class="password-wrapper">

                        @* Campo de contraseña *@
                        @Html.PasswordFor(m => m.Clave, new { @class = "form-control", id = "Clave" })

                        @* Botón reutilizable para mostrar u ocultar la contraseña *@
                        <button type="button"
                                class="password-toggle"
                                data-target="Clave">
                            Ver
                        </button>
                    </div>

                    @* Mensaje de validación para contraseña obligatoria *@
                    @Html.ValidationMessageFor(m => m.Clave, "", new { @class = "text-danger login-validacion" })
                </div>

                <button type="submit" class="btn btn-success btn-block login-btn">
                    Ingresar
                </button>
            }

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    @* Script reutilizable para mostrar u ocultar contraseñas *@
    <script src="@Url.Content("~/Scripts/app/password-toggle.js?v=1")"></script>
}