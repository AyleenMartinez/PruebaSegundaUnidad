@model PruebaSegundaUnidad.Models.LoginViewModel
@{ ViewBag.Title = "Iniciar sesión"; }

<div class="login-page">
    <div class="panel panel-primary login-card">
        <div class="panel-heading text-center"><h3>TechHelpWeb</h3></div>
        <div class="panel-body">
            @if (ViewBag.Error != null)
            {<div class="alert alert-danger">@ViewBag.Error</div>}
            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Usuario o Correo</label>
                    @Html.TextBoxFor(m => m.UsuarioOCorreo, new { @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Contraseña</label>
                    @Html.PasswordFor(m => m.Clave, new { @class = "form-control" })
                </div>
                <button type="submit" class="btn btn-success btn-block">Ingresar</button>
            }
        </div>
    </div>
</div>