@using System.Collections.Generic
@model PruebaSegundaUnidad.Models.SolicitudSoporte

@{
    ViewBag.Title = "Solicitudes de Soporte";

    // Áreas enviadas desde SolicitudesController.
    var areas = ViewBag.Areas as List<PruebaSegundaUnidad.Models.AreaSolicitante>;

    // Tipos de problema enviados desde SolicitudesController.
    var tiposProblema = ViewBag.TiposProblema as List<PruebaSegundaUnidad.Models.TipoProblema>;
}

@* CSS propio del módulo Solicitudes *@
<link href="@Url.Content("~/Content/solicitudes.css")" rel="stylesheet" />

@* Datos de sesión disponibles para el JavaScript externo *@
<input type="hidden" id="UsuarioActualId" value="@Session["UsuarioId"]" />
<input type="hidden" id="RolUsuario" value="@Session["Rol"]" />

<div class="row">
    <div class="col-md-12">

        <h2>Gestión de Soporte Técnico</h2>

        @* JavaScript muestra aquí mensajes de éxito o error *@
        <div id="alertasContainer"></div>

    </div>
</div>

<div class="row">

    @* Formulario para crear una nueva solicitud *@
    <div class="col-md-4">

        <div class="panel panel-default panel-soporte">
            <div class="panel-heading">
                Nueva solicitud
            </div>

            <div class="panel-body">

                @* Este formulario se envía con JavaScript usando fetch hacia la API *@
                <form id="frmNuevaSolicitud">

                    <div class="form-group">
                        <label>Solicitante</label>
                        <input type="text" class="form-control" value="@Session["NombreCompleto"]" readonly />
                    </div>

                    <div class="form-group">
                        <label>Área <span class="text-danger">*</span></label>

                        <select class="form-control" id="IdArea" required>
                            <option value="">-- Seleccione área --</option>

                            @if (areas != null)
                            {
                                foreach (var area in areas)
                                {
                                    <option value="@area.Id">@area.NombreArea</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Tipo de problema <span class="text-danger">*</span></label>

                        <select class="form-control" id="IdTipoProblema" required>
                            <option value="">-- Seleccione problema --</option>

                            @if (tiposProblema != null)
                            {
                                foreach (var tipo in tiposProblema)
                                {
                                    <option value="@tipo.Id">@tipo.NombreTipoProblema</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Prioridad <span class="text-danger">*</span></label>

                        <select class="form-control" id="IdPrioridad" required>
                            <option value="1">Baja</option>
                            <option value="2" selected>Media</option>
                            <option value="3">Alta</option>
                        </select>

                        <div class="campo-ayuda">
                            Baja: menos urgente | Media: normal | Alta: requiere atención rápida
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Descripción <span class="text-danger">*</span></label>

                        <textarea class="form-control"
                                  id="Descripcion"
                                  rows="4"
                                  minlength="10"
                                  required
                                  placeholder="Describe el problema con al menos 10 caracteres"></textarea>

                        <span id="contadorDescripcion" class="contador-descripcion contador-error">
                            0/10 caracteres mínimos
                        </span>
                    </div>

                    <button type="submit" class="btn btn-success btn-block">
                        Guardar solicitud
                    </button>

                </form>

            </div>
        </div>

    </div>

    @* Tabla donde JavaScript carga el historial desde la API *@
    <div class="col-md-8">

        <div class="panel panel-default panel-soporte">
            <div class="panel-heading">
                Historial de solicitudes
            </div>

            <div class="panel-body">

                <div class="table-responsive">

                    <table class="table table-striped table-hover tabla-solicitudes" id="tablaSolicitudes">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th class="columna-fecha">Fecha</th>
                                <th>Usuario</th>
                                <th>Problema</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                                <th class="columna-acciones">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @* Scripts/app/solicitudes.js inserta aquí las solicitudes *@
                        </tbody>
                    </table>

                </div>

            </div>
        </div>

    </div>

</div>

@* Modal Bootstrap para mostrar el detalle de una solicitud *@
<div class="modal fade" id="modalDetalleSolicitud" tabindex="-1" role="dialog" aria-labelledby="tituloModalDetalle">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header">

                <button type="button" class="close" onclick="cerrarModalDetalle()" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>

                <h4 class="modal-title" id="tituloModalDetalle">
                    Detalle de la solicitud
                </h4>
            </div>

            <div class="modal-body">
                <p><strong>ID:</strong> <span id="detalleId"></span></p>
                <p><strong>Solicitante:</strong> <span id="detalleUsuario"></span></p>
                <p><strong>Área:</strong> <span id="detalleArea"></span></p>
                <p><strong>Problema:</strong> <span id="detalleProblema"></span></p>
                <p><strong>Prioridad:</strong> <span id="detallePrioridad"></span></p>
                <p><strong>Estado:</strong> <span id="detalleEstado"></span></p>

                <hr />

                <p><strong>Descripción:</strong></p>
                <div id="detalleDescripcion" class="descripcion-modal"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-default" onclick="cerrarModalDetalle()">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @* Script externo que consume la API de solicitudes *@
    <script src="@Url.Content("~/Scripts/app/solicitudes.js?v=3")"></script>
}