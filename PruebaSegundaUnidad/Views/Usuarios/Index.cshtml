@model IEnumerable<PruebaSegundaUnidad.Models.Usuario>

@{
    ViewBag.Title = "Gestión de Usuarios";
}

<link href="@Url.Content("~/Content/usuarios.css")" rel="stylesheet" />

<div class="row">
    <div class="col-md-12">

        <h2 class="page-header">
            Administración de Usuarios

            <a href="@Url.Action("Crear", "Usuarios")" class="btn btn-success pull-right">
                Nuevo Usuario
            </a>
        </h2>

    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered tabla-usuarios">

        <thead>
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Creación</th>
                <th class="text-center columna-acciones">Acciones</th>
            </tr>
        </thead>

        <tbody>

            @* Se revisa si existen usuarios para mostrar en la tabla *@
            @if (Model != null && Model.Any())
            {
                foreach (var usuario in Model)
                {
                    <tr>
                        <td>@usuario.NombreCompleto</td>
                        <td>@usuario.Correo</td>
                        <td>@usuario.NombreRol</td>

                        <td>
                            @if (usuario.Estado)
                            {
                                <span class="label label-success">Activo</span>
                            }
                            else
                            {
                                <span class="label label-danger">Inactivo</span>
                            }
                        </td>

                        <td>@usuario.FechaRegistro.ToString("dd-MM-yyyy")</td>

                        <td class="text-center">

                            @* Abre el formulario para editar los datos del usuario *@
                            <a href="@Url.Action("Editar", "Usuarios", new { id = usuario.Id })"
                               class="btn btn-info btn-sm">
                                Editar
                            </a>

                            @* Cambia el estado activo/inactivo del usuario *@
                            @if (usuario.Estado)
                            {
                                <a href="@Url.Action("CambiarEstado", "Usuarios", new { id = usuario.Id })"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('¿Estás seguro de que deseas desactivar a este usuario?');">
                                    Desactivar
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("CambiarEstado", "Usuarios", new { id = usuario.Id })"
                                   class="btn btn-success btn-sm"
                                   onclick="return confirm('¿Estás seguro de que deseas reactivar a este usuario?');">
                                    Activar
                                </a>
                            }

                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">
                        No hay usuarios registrados en el sistema.
                    </td>
                </tr>
            }

        </tbody>
    </table>
</div>