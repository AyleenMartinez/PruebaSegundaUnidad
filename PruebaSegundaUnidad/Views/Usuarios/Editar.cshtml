@model PruebaSegundaUnidad.Models.Usuario

@{
    ViewBag.Title = "Editar Usuario";
}

<link href="@Url.Content("~/Content/usuarios.css?v=2")" rel="stylesheet" />

<div class="usuarios-page">

    <div class="formulario-usuario-header">
        <div>
            <span class="usuarios-etiqueta">Edición de cuenta</span>

            <h2>Editar usuario</h2>

            <p>
                Actualiza datos de cuenta, rol y estado de acceso del usuario seleccionado.
            </p>
        </div>
    </div>

    <div class="formulario-usuario-card">

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @* Formulario MVC que envía los cambios al método Editar del UsuariosController *@
        @using (Html.BeginForm("Editar", "Usuarios", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @* Se mantiene el Id del usuario editado *@
            @Html.HiddenFor(m => m.Id)

            <div class="row">

                <div class="col-md-6 form-group usuario-form-group">
                    <label>Nombre completo <span class="text-danger">*</span></label>

                    @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control" })

                    @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6 form-group usuario-form-group">
                    <label>Nombre de usuario <span class="text-danger">*</span></label>

                    @Html.TextBoxFor(m => m.NombreUsuario, new { @class = "form-control" })

                    @Html.ValidationMessageFor(m => m.NombreUsuario, "", new { @class = "text-danger" })
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 form-group usuario-form-group">
                    <label>Correo electrónico <span class="text-danger">*</span></label>

                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email" })

                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6 form-group usuario-form-group">
                    <label>Rol en el sistema <span class="text-danger">*</span></label>

                    <select class="form-control" name="RolId" required>
                        @foreach (var rol in ViewBag.Roles)
                        {
                            <option value="@rol.Id" @(Model.RolId == rol.Id ? "selected" : "")>
                                @rol.NombreRol
                            </option>
                        }
                    </select>

                    @Html.ValidationMessageFor(m => m.RolId, "", new { @class = "text-danger" })
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 form-group usuario-form-group">
                    <label>Estado <span class="text-danger">*</span></label>

                    <select class="form-control" name="Estado" required>
                        <option value="true" @(Model.Estado ? "selected" : "")>Activo</option>
                        <option value="false" @(!Model.Estado ? "selected" : "")>Inactivo</option>
                    </select>

                    <span class="campo-ayuda-usuario">
                        Un usuario inactivo no podrá iniciar sesión.
                    </span>
                </div>

            </div>

            <div class="acciones-formulario-usuario">

                <a href="@Url.Action("Index", "Usuarios")" class="btn btn-cancelar-usuario">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-guardar-usuario">
                    Guardar cambios
                </button>

            </div>
        }

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}