<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - TechHelpWeb</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    @{
        // Se obtiene la ruta actual para saber en qué pantalla estamos.
        var controllerActual = ViewContext.RouteData.Values["controller"] != null
            ? ViewContext.RouteData.Values["controller"].ToString()
            : "";

        var actionActual = ViewContext.RouteData.Values["action"] != null
            ? ViewContext.RouteData.Values["action"].ToString()
            : "";

        // El Dashboard principal no muestra botón Volver.
        var esDashboardPrincipal = controllerActual == "Home" && actionActual == "Index";

        // En Login no se muestra el link Iniciar sesión.
        var esLogin = controllerActual == "Auth" && actionActual == "Login";

        // Se revisa si hay sesión activa.
        var haySesion = Session["UsuarioId"] != null;

        // Rol del usuario conectado.
        var rolUsuario = Session["Rol"] != null ? Session["Rol"].ToString() : "";

        // Clases para marcar visualmente el menú activo.
        var claseInicio = controllerActual == "Home" ? "nav-link nav-link-activo" : "nav-link";
        var claseSolicitudes = controllerActual == "Solicitudes" ? "nav-link nav-link-activo" : "nav-link";
        var clasePerfil = controllerActual == "Perfil" ? "nav-link nav-link-activo" : "nav-link";
        var claseUsuarios = controllerActual == "Usuarios" ? "nav-link nav-link-activo" : "nav-link";
    }

    @* Navbar general del sistema *@
    <nav class="navbar navbar-expand-sm navbar-dark navbar-techhelp">
        <div class="container nav-contenedor">

            @* Nombre del sistema *@
            @Html.ActionLink("TechHelpWeb", "Index", "Home", new { area = "" }, new { @class = "navbar-brand marca-techhelp" })

            @* Botón responsive para pantallas pequeñas *@
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menuPrincipal"
                    aria-controls="menuPrincipal"
                    aria-expanded="false"
                    aria-label="Mostrar menú">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">

                <ul class="navbar-nav menu-principal">

                    @if (haySesion)
                    {
                        @* Menú principal visible solo con sesión activa *@
                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = claseInicio })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Solicitudes", "Index", "Solicitudes", null, new { @class = claseSolicitudes })
                        </li>

                        <li class="nav-item">
                            @Html.ActionLink("Mi Perfil", "Index", "Perfil", null, new { @class = clasePerfil })
                        </li>

                        @* Usuarios solo aparece para Administrador *@
                        if (rolUsuario == "Administrador")
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Usuarios", "Index", "Usuarios", null, new { @class = claseUsuarios })
                            </li>
                        }
                    }

                </ul>

                <ul class="navbar-nav menu-sesion">

                    @if (haySesion)
                    {
                        @* Muestra usuario y rol conectado *@
                        <li class="nav-item nav-usuario">
                            <span class="usuario-navbar">
                                <strong>@Session["NombreCompleto"]</strong>

                                @if (Session["Rol"] != null)
                                {
                                    <small>@Session["Rol"]</small>
                                }
                            </span>
                        </li>

                        @* Cierre de sesión *@
                        <li class="nav-item">
                            <a href="@Url.Action("Logout", "Auth")" class="btn btn-logout">
                                Cerrar sesión
                            </a>
                        </li>
                    }
                    else
                    {
                        @* Link de login solo si no estamos ya en Login *@
                        if (!esLogin)
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Iniciar sesión", "Login", "Auth", null, new { @class = "nav-link nav-login" })
                            </li>
                        }
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container body-content">

        @* Botón volver para vistas internas, excepto Dashboard *@
        @if (haySesion && !esDashboardPrincipal)
        {
            <div class="volver-contenedor">
                <button type="button" class="btn btn-volver" onclick="volverPaginaAnterior()">
                    ← Volver
                </button>
            </div>
        }

        @* Aquí se carga cada vista *@
        @RenderBody()

        <hr class="footer-linea" />

        <footer class="footer-techhelp">
            <p>&copy; @DateTime.Now.Year - TechHelpWeb</p>
        </footer>

    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>
        // Función general para volver desde vistas internas.
        function volverPaginaAnterior() {

            // Si hay historial, vuelve a la página anterior.
            if (window.history.length > 1) {
                window.history.back();
            }

            // Si no hay historial, vuelve al dashboard.
            else {
                window.location.href = '@Url.Action("Index", "Home")';
            }
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>